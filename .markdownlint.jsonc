// markdownlint config. Goal: catch broken markdown, not nag about style.
{
  "default": true,
  // Allow long lines — SKILL.md prose often runs long and reflowing it hurts diffs.
  "MD013": false,
  // Allow inline HTML — useful for occasional <details> blocks.
  "MD033": false,
  // First line doesn't have to be a heading (frontmatter comes first).
  "MD041": false,
  // Allow duplicate headings under different parents (e.g. "How to use this skill").
  "MD024": { "siblings_only": true }
}
